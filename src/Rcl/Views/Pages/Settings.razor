@page "/settings"

<MudPaper Class="pa-6 d-flex flex-column gap-4" Elevation="1">
    <MudText Typo="Typo.h4">Settings</MudText>

    <MudText Typo="Typo.body2" Class="mud-secondary-text">
        Manage application-level preferences.
    </MudText>

    <MudButton Href="/settings/color-profiles"
               Variant="Variant.Outlined"
               StartIcon="@Icons.Material.Filled.Palette">
        Color Profiles
    </MudButton>
</MudPaper>
