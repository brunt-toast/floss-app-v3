@page "/settings"
@using Rcl.Resources.Languages

<MudPaper Class="pa-6 d-flex flex-column gap-4" Elevation="1">
    <MudText Typo="Typo.h4">@SettingsResources.Title</MudText>

    <MudText Typo="Typo.body2" Class="mud-secondary-text">
        @SettingsResources.Description
    </MudText>

    <MudButton Href="/settings/color-profiles"
               Variant="Variant.Outlined"
               StartIcon="@Icons.Material.Filled.Palette">
        @SettingsResources.ColorProfilesLink
    </MudButton>

    <MudButton Href="/settings/about"
               Variant="Variant.Outlined"
               StartIcon="@Icons.Material.Filled.Info">
        @SettingsResources.AboutLink
    </MudButton>
</MudPaper>
