@page "/image-workbench"
@using App.Enums
@using Rcl.Resources.Languages
@using Rcl.Views.Components

<MudGrid Spacing="2">
    <MudItem xs="12">
        <div class="workbench-section pa-3">
            @if (!string.IsNullOrWhiteSpace(ViewModel.ResultPreviewDataUrl))
            {
                <div class="processed-preview-shell mt-2">
                    <img src="@ViewModel.ResultPreviewDataUrl" alt="@ImageWorkbenchResources.ProcessedImageAlt" class="processed-preview-image"/>
                </div>
                <MudText Typo="Typo.caption">
                    @if (ViewModel.ResultWidth > 0 && ViewModel.ResultHeight > 0)
                    {
                        <span>@ViewModel.ResultWidth x @ViewModel.ResultHeight</span>
                    }
                </MudText>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-2">
                    @ImageWorkbenchResources.ProcessedPreviewPlaceholder
                </MudAlert>
            }
        </div>
    </MudItem>

    <MudItem xs="12">
        <div class="workbench-section pa-3">
            <MudStack Spacing="2">
                <MudText Typo="Typo.body2" Color="Color.Inherit">
                    @ImageWorkbenchResources.ScaleLabel
                </MudText>
                <MudSlider T="double"
                           Min="0.01"
                           Max="1"
                           Step="0.01"
                           Immediate="true"
                           @bind-Value="ViewModel.Scale"
                           ValueLabel="true"
                           Disabled="@(!ViewModel.HasImage || ViewModel.IsBusy)"/>

                <MudText Typo="Typo.body2" Color="Color.Inherit">@ImageWorkbenchResources.TransparencyThresholdLabel</MudText>
                <MudSlider T="int"
                           Min="0"
                           Max="255"
                           Step="1"
                           Immediate="true"
                           Value="@ViewModel.TransparencyThreshold"
                           ValueChanged="OnTransparencyChanged"
                           ValueLabel="true"
                           Disabled="@(!ViewModel.HasImage || ViewModel.IsBusy)"/>

                <MudText Typo="Typo.body2" Color="Color.Inherit">@ImageWorkbenchResources.ColorFidelityLabel</MudText>
                <MudSlider T="int"
                           Min="1"
                           Max="@Math.Max(1, ViewModel.MaximumColorFidelity)"
                           Step="1"
                           Immediate="true"
                           Value="@GetSelectedColorFidelityValue()"
                           ValueChanged="OnColorFidelityChanged"
                           ValueLabel="true"
                           Disabled="@(!ViewModel.HasImage || ViewModel.IsBusy || ViewModel.MaximumColorFidelity <= 1)"/>

                <MudGrid Spacing="2">
                    <MudItem xs="6" md="6">
                        <EnumPicker T="ImageSharpKnownResamplers"
                                    Label="@ImageWorkbenchResources.ResamplerLabel"
                                    Value="@ViewModel.SelectedResampler"
                                    ValueChanged="OnResamplerChanged"
                                    Filter="CanUseResampler"
                                    Disabled="@(!ViewModel.HasImage || ViewModel.IsBusy)"/>
                    </MudItem>

                    <MudItem xs="6" md="6">
                        <EnumPicker T="ImageSharpKnownDitherings"
                                    Label="@ImageWorkbenchResources.DitheringLabel"
                                    Value="@ViewModel.SelectedDithering"
                                    ValueChanged="OnDitheringChanged"
                                    Filter="CanUseDithering"
                                    Disabled="@(!ViewModel.HasImage || ViewModel.IsBusy)"/>
                    </MudItem>

                    <MudItem xs="6" md="6">
                        <MudSelect T="string"
                                   Label="@ImageWorkbenchResources.ColorSetLabel"
                                   Value="@ViewModel.SelectedColorSetKey"
                                   ValueChanged="OnColorSetChanged"
                                   Disabled="@(!ViewModel.HasImage || ViewModel.IsBusy || ViewModel.ColorSets.Count == 0)">
                            @foreach (var profile in ViewModel.ColorSets)
                            {
                                <MudSelectItem T="string" Value="@profile.Key">@profile.Name</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="6" md="6">
                        <EnumPicker T="ColorComparisonAlgorithms"
                                    Label="@ImageWorkbenchResources.ColorDistanceLabel"
                                    Value="@ViewModel.SelectedComparisonAlgorithm"
                                    ValueChanged="OnComparisonAlgorithmChanged"
                                    Filter="CanUseComparisonAlgorithm"
                                    Disabled="@(!ViewModel.HasImage || ViewModel.IsBusy)"/>
                    </MudItem>
                </MudGrid>

                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1" Class="workbench-actions mt-1">
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.FolderOpen"
                               Disabled="@ViewModel.IsBusy"
                               Size="Size.Medium"
                               Class="workbench-action-button"
                               OnClick="LoadFromDeviceAsync">
                        @ImageWorkbenchResources.LoadButton
                    </MudButton>

                    <MudButton Color="Color.Primary"
                               Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.Download"
                               Disabled="@(!ViewModel.CanSave)"
                               Size="Size.Medium"
                               Class="workbench-action-button"
                               OnClick="SaveResultAsync">
                        @ImageWorkbenchResources.SaveButton
                    </MudButton>
                </MudStack>

            </MudStack>
        </div>
    </MudItem>

    @if (ViewModel.ColorUsage.Count > 0)
    {
        <MudItem xs="12">
            <div class="workbench-section pa-3">
                <MudExpansionPanels>
                    <MudExpansionPanel Text="@ImageWorkbenchResources.ColorUsagePanelTitle">
                        <MudText Typo="Typo.body2" Class="mud-secondary-text mb-3">
                            @GetColorUsageSummary()
                        </MudText>

                        <div class="color-usage-list">
                            @foreach (var colorUsage in ViewModel.ColorUsage)
                            {
                                <div class="color-usage-row">
                                    <span class="color-usage-swatch" style="background-color:@colorUsage.Hex;"></span>
                                    <span class="color-usage-name">@colorUsage.Name</span>
                                    @if (!string.IsNullOrWhiteSpace(colorUsage.Floss))
                                    {
                                        <span class="color-usage-code">(@colorUsage.Floss)</span>
                                    }
                                    <span class="color-usage-count">x@(colorUsage.PixelCount.ToString("N0"))</span>
                                </div>
                            }
                        </div>
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </div>
        </MudItem>
    }
</MudGrid>

@if (ViewModel.IsBusy)
{
    <MudProgressLinear Indeterminate="true" Class="mt-3" Color="Color.Primary"/>
}
