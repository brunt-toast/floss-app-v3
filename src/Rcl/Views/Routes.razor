<MudThemeProvider Theme="Theme"/>
<MudPopoverProvider/>
<MudDialogProvider/>
<MudSnackbarProvider/>

<Router AppAssembly="typeof(Routes).Assembly" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)"/>
        <FocusOnNavigate RouteData="routeData" Selector="h1"/>
    </Found>
</Router>

@code {

    private static readonly MudTheme Theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1ec8a5",
            PrimaryDarken = "#16ad8e",
            PrimaryLighten = "#5fdcc3",
            Secondary = "#0f766e",
            Tertiary = "#115e59",
            AppbarBackground = "#1ec8a5",
            AppbarText = "#ffffff",
            DrawerBackground = "#f6fffc",
            Background = "#f8fffd",
            Surface = "#ffffff"
        }
    };

}
